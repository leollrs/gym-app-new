<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="false"
        android:largeHeap="true"
        android:localeConfig="@xml/locales_config"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                SECURITY: Custom URI schemes (tugympr://, com.tugympr.app://) are NOT
                verified by Android — any malicious app can register the same scheme and
                intercept deep links (intent hijacking). Only Android App Links with
                autoVerify="true" and a valid /.well-known/assetlinks.json on the domain
                are cryptographically verified.

                The tugympr:// scheme was only used by iOS Siri Shortcuts
                (AppIntents.swift) and is not referenced by any Android or web code.
                The com.tugympr.app:// scheme was unused (Capacitor uses androidScheme:
                "https", not a custom URL scheme).

                Both custom schemes have been removed. All deep linking on Android should
                use verified App Links (https://tugympr.com/...) below.

                If you must re-add a custom scheme (e.g., for push notification deep
                links), limit exposure by NOT including BROWSABLE category, or validate
                the caller in MainActivity.onCreate() before acting on the intent.
            -->

            <!-- Android App Links (verified): https://tugympr.com deep links.
                 Requires /.well-known/assetlinks.json hosted at tugympr.com with the
                 app's signing certificate SHA-256 fingerprint. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="tugympr.com" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Workout tracking handled in foreground WebView; no foreground service required. iOS uses Live Activities. -->

        <!-- Home screen widget -->
        <receiver
            android:name=".WorkoutWidget"
            android:permission="android.permission.BIND_APPWIDGET"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/workout_widget_info" />
        </receiver>

        <!-- FCM default notification channel -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/colorAccent" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="tugympr_default" />
    </application>

    <!-- Permissions: Networking -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Permissions: Location (GPS check-in) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Permissions: Camera (QR scanning, food photos, progress photos) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Permissions: Storage (photo access)
         Notes:
         - READ_EXTERNAL_STORAGE: legacy gallery read, scoped to API ≤32 only.
         - WRITE_EXTERNAL_STORAGE: legacy write, scoped to API ≤29 only (scoped storage on 30+).
         - READ_MEDIA_IMAGES / READ_MEDIA_VIDEO are intentionally NOT declared.
           App uses the system Photo Picker via Capacitor Camera v8 (CameraSource.Photos)
           and one-shot HTML <input type="file"> for background photos and progress photos.
           The Photo Picker / file input require NO media permissions on Android API 33+,
           and we never enumerate the full gallery or read video libraries. Omitting these
           permissions also removes the Google Play Photo & Video Permissions Declaration
           requirement.
         - READ_MEDIA_VISUAL_USER_SELECTED (API 34+): kept so the OS treats partial-photo
           access (the new "Select photos…" option) as granted instead of denied if a
           future code path ever requests media access. Safe to ship without the broader
           media perms above. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <!-- Permissions: Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Permissions: Haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Permissions: Boot (scheduled notifications) -->
    <!-- Justified by @capacitor/local-notifications: the plugin contributes
         <receiver android:name="com.capacitorjs.plugins.localnotifications.LocalNotificationRestoreReceiver">
         (with intent-filters for BOOT_COMPLETED / LOCKED_BOOT_COMPLETED / QUICKBOOT_POWERON)
         via manifest merge, so scheduled local notifications survive device reboots.
         See android/app/build/intermediates/merged_manifest for the resolved version. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Permissions: Health / fitness (activity recognition for health plugin) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.WRITE_EXERCISE" />
    <uses-permission android:name="android.permission.health.WRITE_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.WRITE_WEIGHT" />

    <!--
         Suppress unused permissions auto-injected by @capgo/capacitor-health to comply
         with Play Health Apps attestation policy. The plugin's manifest declares 39
         Health Connect permissions, but TuGymPR only uses 7 (declared above). All
         others are removed via tools:node="remove" so they do not appear in the merged
         manifest, the Play permission declaration form, or the Health Connect
         permission picker shown to the user.

         If a new health data type is ever needed, delete the corresponding remove line
         AND add the matching uses-permission above.
    -->
    <uses-permission android:name="android.permission.health.WRITE_STEPS" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_DISTANCE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_ACTIVE_CALORIES_BURNED" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_HEART_RATE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_SLEEP" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_RESPIRATORY_RATE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_OXYGEN_SATURATION" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_RESTING_HEART_RATE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_HEART_RATE_VARIABILITY" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_BLOOD_PRESSURE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_BLOOD_PRESSURE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_BLOOD_GLUCOSE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_BLOOD_GLUCOSE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_BODY_TEMPERATURE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_BODY_TEMPERATURE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_HEIGHT" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_HEIGHT" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_FLOORS_CLIMBED" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_FLOORS_CLIMBED" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_BODY_FAT" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_BODY_FAT" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_BASAL_BODY_TEMPERATURE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_BASAL_BODY_TEMPERATURE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_BASAL_METABOLIC_RATE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_BASAL_METABOLIC_RATE" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_MINDFULNESS" tools:node="remove" />
    <uses-permission android:name="android.permission.health.WRITE_MINDFULNESS" tools:node="remove" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" tools:node="remove" />

    <!-- Hardware feature declarations (optional, not required) -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <!-- Health Connect intent for privacy policy -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

</manifest>
