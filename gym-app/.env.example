# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=your-posthog-project-token-here
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Mapbox public token for Static Images API (used by the cardio share card).
# Create at https://account.mapbox.com/access-tokens — restrict to your app's
# referrer/bundle ID. Free tier: 50,000 static map renders / month.
# Without this, the share card falls back to client-side OSM tile stitching.
VITE_MAPBOX_TOKEN=
