<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>IronForge</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UIRequiresFullScreen</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- Lock to portrait on iPhone -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!-- Allow rotation on iPad -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- App Transport Security — allow web content connections -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<true/>
	</dict>

	<!-- Background modes for health sync and OTA updates -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>

	<!-- Privacy usage descriptions (required by App Store) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>IronForge uses your location to verify you're at the gym for check-in.</string>
	<key>NSCameraUsageDescription</key>
	<string>IronForge uses your camera to scan QR codes for gym check-in and to take progress photos.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>IronForge accesses your photo library to upload profile pictures and progress photos.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>IronForge saves progress photos and workout summaries to your photo library.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>IronForge reads your health data to display steps, sync weight measurements, and track workout activity.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>IronForge saves your workouts and weight logs to Apple Health so all your fitness data stays in one place.</string>

	<!-- Export compliance — only HTTPS (exempt encryption) -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
